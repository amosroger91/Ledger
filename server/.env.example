# ── Ledger server config (all optional; sane defaults shown) ──────────────
# Render injects PORT automatically — leave unset there.
PORT=8787

# Gun graph root. MUST match the frontend's ROOT (src/services/gunService.ts).
# The frontend currently uses "zuccbook-v1"; if you rename it to "ledger-v1",
# change it in BOTH places together (existing graph data won't carry over).
GUN_ROOT=zuccbook-v1

# Where Gun's radisk persists the graph. EPHEMERAL on Render's free tier
# (wiped on redeploy / spin-down). Mount a Render Disk and point this at it
# (e.g. /var/data) for durable 24/7 persistence.
GUN_DATA_DIR=./data

# Public Gun relays to also sync FROM, so a freshly-woken relay bootstraps warm.
GUN_PEERS=https://gun-manhattan.herokuapp.com/gun,https://peer.wallie.io/gun,https://relay.peer.ooo/gun

# RSS aggregation tuning.
RSS_REFRESH_MS=600000
RSS_CONCURRENCY=4
RSS_FETCH_TIMEOUT_MS=12000
RSS_MAX_ITEMS=800

# Public/self-hosted RSSHub base — used to ingest sources with no native RSS
# (Twitch, Instagram, etc.). Leave blank to disable the RSSHub helpers.
RSSHUB_BASE=https://rsshub.app

# CORS: "*" allows any origin (GitHub Pages / your custom domain), or a CSV list.
CORS_ORIGIN=*
